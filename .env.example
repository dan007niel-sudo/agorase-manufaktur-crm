# API service only. Never expose provider secrets in Vite client env.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
ALLOWED_ORIGINS=http://localhost:5173
PORT=8787
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agorase_fashion_os
ADMIN_PASSWORD=
SESSION_SECRET=

# Web development proxy target. Local only.
VITE_API_PROXY_TARGET=http://localhost:8787

# Web production API origin. Leave EMPTY in production — Render rewrites
# /api/* same-origin to the API service (see render.yaml routes), which lets
# the session cookie travel as first-party in WebKit/iOS browsers.
# For local dev you can leave this empty too; Vite proxies /api to
# VITE_API_PROXY_TARGET (see apps/web/vite.config.ts).
VITE_API_BASE_URL=
