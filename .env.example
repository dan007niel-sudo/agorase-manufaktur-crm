# API service only. Never expose provider secrets in Vite client env.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
ALLOWED_ORIGINS=http://localhost:5173
PORT=8787
